# ── Database ───────────────────────────────────────────────────────────────────
# Railway sets these automatically from the PostgreSQL plugin.
# Locally, fill in your local PostgreSQL details.
PGHOST=localhost
PGPORT=5432
PGDATABASE=kostonemarble_db
PGUSER=postgres
PGPASSWORD=<your-postgres-password>

# ── JWT (generate a long random hex string) ───────────────────────────────────
JWT_SIGNING_KEY=<64-char-random-hex>

# ── Email (optional — app works without it) ───────────────────────────────────
KOSTONE_SYSTEM_EMAIL=kostonemarble@gmail.com
KOSTONE_EMAIL_PASSWORD=<gmail-app-password>

# ── Twilio WhatsApp (optional) ────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── URLs & Storage ────────────────────────────────────────────────────────────
BASE_URL=http://localhost:5173
UPLOAD_DIR=/tmp/uploads
PORT=8080
