# Database (Railway PostgreSQL plugin provides these)
SPRING_DATASOURCE_URL=jdbc:postgresql://<railway-host>:<port>/kostonemarble_db
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=

# Application email
KOSTONE_SYSTEM_EMAIL=kostonemarble@gmail.com
KOSTONE_EMAIL_PASSWORD=

# JWT
JWT_SIGNING_KEY=

# Storage
STORAGE_BUCKET_ENDPOINT=https://storage.railway.app/kostonemarble-assets

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Server (Railway injects PORT automatically)
PORT=8080
