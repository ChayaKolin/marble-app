# Database (Railway PostgreSQL plugin provides these)
SPRING_DATASOURCE_URL=jdbc:postgresql://<railway-host>:<port>/railway?sslmode=require
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=<paste-from-railway-postgres-variables>

# Application email
KOSTONE_SYSTEM_EMAIL=kostonemarble@gmail.com
KOSTONE_EMAIL_PASSWORD=<gmail-app-password>

# JWT (generate a long random string)
JWT_SIGNING_KEY=<64-char-random-string>

# Twilio WhatsApp (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# URLs
BASE_URL=https://kostonemarble-production.up.railway.app
UPLOAD_DIR=/tmp/uploads
